// DAX measures for table: xy
// Auto-generated by Tableau → Power BI migration

Number of Records =
1

SUM(X) + SUM(Y) =
SUM('xy'[x]) + SUM('xy'[y])

SUM(X) + SUM(Y) Formatted =
VAR _val = [SUM(X) + SUM(Y)] RETURN IF(ABS(_val) >= 1E9, FORMAT(_val / 1E9, "#,0.0") & "B", IF(ABS(_val) >= 1E6, FORMAT(_val / 1E6, "#,0.0") & "M", IF(ABS(_val) >= 1E3, FORMAT(_val / 1E3, "#,0.0") & "K", FORMAT(_val, "0"))))

