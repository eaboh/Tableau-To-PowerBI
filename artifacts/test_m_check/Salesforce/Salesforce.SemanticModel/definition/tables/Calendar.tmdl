table Calendar
	lineageTag: 0b6c5400-f68a-4912-9ad9-57b52ce99da5

	measure 'Year To Date' = TOTALYTD([Pipeline Generated], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 3a01bd67-24ab-4c7b-9a63-9864e54f7a75
		annotation Copilot_Description = DAX: TOTALYTD([Pipeline Generated], 'Calendar'[Date])

	measure 'Previous Year' = CALCULATE([Pipeline Generated], SAMEPERIODLASTYEAR('Calendar'[Date]))
