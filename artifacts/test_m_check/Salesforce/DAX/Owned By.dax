Pipeline Profile - Total Sales (description) =
SWITCH([Pipeline Profile - Total Sales], "1", "VERY LOW", "2", "LOW", "3", "MEDIUM", "4", "HIGH", "5", "VERY HIGH") & " Ability to sell"

Pipeline Profile - Pipeline Generation to Prospects (description) =
SWITCH([Pipeline Profile - Pipeline Generation to Prospects], "1", "VERY LOW", "2", "LOW", "3", "MEDIUM", "4", "HIGH", "5", "VERY HIGH") & " Ability to generate pipeline with prospects"

Pipeline Profile - Total Sales (num) =
INT([Pipeline Profile - Total Sales])

Pipeline Profile - Pipeline Generation to Prospects (num) =
INT([Pipeline Profile - Pipeline Generation to Prospects])

Probability (bucket) (sort) =
IF(MAX('Owned By'[_Avg Probability (Expression)]) < 0.25, 10, IF(MAX('Owned By'[_Avg Probability (Expression)]) < 0.50, 20, IF(MAX('Owned By'[_Avg Probability (Expression)]) < 0.75, 30, 40)))

Sales Value (for selected Opp Owner) =
MAXX('Owned By', IF('Owned By'[Is Selected Opportunity Owner Flag?], CALCULATE([Total Sales]), BLANK()))

Rank Conversion Rate (for selected Opp Owner) =
/* TODO: DAX conversion validation failed for Rank Sales Value (for selected Opp Owner) (copy)_1048775823272144897: unterminated double-quoted string literal */ BLANK()

Rank Total Opp Amount (for selected Opp Owner) =
/* TODO: DAX conversion validation failed for Rank Sales Value (for selected Opp Owner) (copy)_928867483237888003: unterminated double-quoted string literal */ BLANK()

Conversion Rate (for selected Opp Owner) =
MAXX('Owned By', IF('Owned By'[Is Selected Opportunity Owner Flag?], CALCULATE('Owned By'[Conversion Rate]), BLANK()))

Total Opp Amount (for selected Opp Owner) =
MAXX('Owned By', IF('Owned By'[Is Selected Opportunity Owner Flag?], CALCULATE([Pipeline Generated]), BLANK()))

Total Closed Opportunities Amount (Last N Months - Closed Date) =
SUMX('Owned By', IF('Owned By'[Is Last N months filter - Closed Date?], 'Owned By'[_Total Closed Opportunities Amount (Expression)], BLANK()))

Average Deal Size (Last N Months - Closed Date) =
SUMX('Owned By', IF('Owned By'[Is Last N months filter - Closed Date?], 'Owned By'[_Avg Deal Size (won) (Expression)], BLANK()))

Pipeline Generation for Existing Clients =
SUMX('Owned By', IF('Owned By'[Client/Prospect by Opportunity]="Existing Clients" && 'Owned By'[Is Last N months filter - Created Date?], 'Owned By'[_Pipeline Generated (Expression)], BLANK()))

Total Sales for Prospects =
SUMX('Owned By', IF('Owned By'[Client/Prospect by Opportunity]="Prospects" && 'Owned By'[Is Last N months filter - Closed Date?], 'Owned By'[_Total Sales (Expression)], BLANK()))

Pipeline Generation for Prospects =
SUMX('Owned By', IF('Owned By'[Client/Prospect by Opportunity]="Prospects" && 'Owned By'[Is Last N months filter - Created Date?], 'Owned By'[_Pipeline Generated (Expression)], BLANK()))

Days from Open to Close =
AVERAGEX('Owned By', CONVERT(DATEDIFF('Owned By'[CreatedDate (Owned By)], 'Owned By'[Opportunity Close Date], MINUTE) / (24*60), DOUBLE))

__MyToday =
DATE(2022,04,18)

Last N Months =
36

KPI_AvgOpportunitySize_Calculation =
"Average of [Opportunity Amount]"

KPI_AvgOpportunitySize_Description =
"Average amount of opportunities, whether they are open or closed (expressed in currency)"

KPI_SalesVelocity_Description =
"Determines how fast you are making money (you bring back about that much every day) (expressed in currency)"

KPI_AvgDealSizeWon_Description =
"Average amount of won opportunities (expressed in currency)"

KPI_TotalClosedOpportunitiesAmount_Description =
"Total amount of opportunities that are closed (expressed in currency)"

