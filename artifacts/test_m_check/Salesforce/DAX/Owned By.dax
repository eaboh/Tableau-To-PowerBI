Pipeline Profile - Pipeline Generation to Existing Clients =
IF(SUM('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]) <= CALCULATE(MAX('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]), ALL('Owned By'))/5, "1", IF(SUM('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]) <= CALCULATE(MAX('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]), ALL('Owned By'))/5*2, "2", IF(SUM('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]) <= CALCULATE(MAX('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]), ALL('Owned By'))/5*3, "3", IF(SUM('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]) <= CALCULATE(MAX('Owned By'[_Per Customer: Pipeline Generation for Existing Clients]), ALL('Owned By'))/5*4, "4", "5"))))

Pipeline Profile - Pipeline Generation to Existing Clients (description) =
SWITCH([Pipeline Profile - Pipeline Generation to Existing Clients], "1", "VERY LOW", "2", "LOW", "3", "MEDIUM", "4", "HIGH", "5", "VERY HIGH") & " Ability to generate pipeline with existing clients"

Pipeline Profile - Pipeline Generation to Existing Clients (num) =
INT([Pipeline Profile - Pipeline Generation to Existing Clients])

Pipeline Profile - Total Sales =
IF(SUM('Owned By'[_Per Customer: Total Sales]) <= CALCULATE(MAX('Owned By'[_Per Customer: Total Sales]), ALL('Owned By'))/5, "1", IF(SUM('Owned By'[_Per Customer: Total Sales]) <= CALCULATE(MAX('Owned By'[_Per Customer: Total Sales]), ALL('Owned By'))/5*2, "2", IF(SUM('Owned By'[_Per Customer: Total Sales]) <= CALCULATE(MAX('Owned By'[_Per Customer: Total Sales]), ALL('Owned By'))/5*3, "3", IF(SUM('Owned By'[_Per Customer: Total Sales]) <= CALCULATE(MAX('Owned By'[_Per Customer: Total Sales]), ALL('Owned By'))/5*4, "4", "5"))))

