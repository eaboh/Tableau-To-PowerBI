table Calendar
	lineageTag: 25fb902b-8f7e-4b5c-9348-40eef00bae60

	measure 'Year To Date' = TOTALYTD([Is My Account], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 9f065754-7a11-4461-af7c-266211a74628
		annotation Copilot_Description = DAX: TOTALYTD([Is My Account], 'Calendar'[Date])

	measure 'Previous Year' = CALCULATE([Is My Account], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: f46268c0-2cd6-454a-8251-5553f610fceb
		annotation Copilot_Description = DAX: CALCULATE([Is My Account], SAMEPERIODLASTYEAR('Calendar'[Date]))

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: 80c78add-f6bc-442b-908c-b9fbf4a30cd7
		annotation Copilot_Description = DAX: DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)

