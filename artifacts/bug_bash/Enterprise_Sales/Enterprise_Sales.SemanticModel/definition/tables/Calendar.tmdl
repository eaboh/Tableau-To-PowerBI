	hierarchy 'Date Hierarchy'
		lineageTag: 9717f9b2-e55c-4b0d-b122-f8e989ebbfdc

		level Year
			ordinal: 0
			column: Year
			lineageTag: 3390c7b1-4f35-495e-89d0-1f199f0ba710

		level Quarter
			ordinal: 1
			column: Quarter
