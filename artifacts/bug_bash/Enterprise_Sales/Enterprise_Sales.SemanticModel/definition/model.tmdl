ref relationship c5209f69-f7ae-4b50-bfd0-1b89c71ded98
ref relationship 48242f17-4004-40fb-97a7-83263ce7367a

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

