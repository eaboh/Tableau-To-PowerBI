      "category": "calculation",
      "name": "Gross Revenue",
      "status": "exact",
      "source_formula": "SUM([quantity] * [unit_price])",
      "dax": "SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price])"
    },
    {
      "category": "calculation",
      "name": "Net Revenue",
      "status": "exact",
      "source_formula": "SUM(IF [order_status] != \"Cancelled\" AND [is_returned] = FALSE THEN [quantity] * [unit_price] * (1 - [discount_pct]) ELSE 0 END)",
      "dax": "SUMX('fact_sales', IF('fact_sales'[order_status] <> \"Cancelled\" && 'fact_sales'[is_returned] = FALSE, 'fact_sales'[quantity] * 'fact_sales'[unit_price] * (1 - 'fact_sales'[discount_pct]), 0))"
    },
    {
      "category": "calculation",
      "name": "COGS",
      "status": "exact",
      "source_formula": "SUM([quantity] * [unit_cost])",
      "dax": "SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_cost])"
    },
    {
      "category": "calculation",
      "name": "Gross Profit",
      "status": "exact",
      "source_formula": "[C_NetRev] - [C_COGS] - SUM([shipping_cost])",
      "dax": "[Net Revenue] - [COGS] - SUM('fact_sales'[shipping_cost])"
    },
    {
      "category": "calculation",
      "name": "Gross Margin %",
      "status": "exact",
      "source_formula": "ZN([C_GrossProfit] / [C_NetRev])",
      "dax": "IF(ISBLANK([Gross Profit] / [Net Revenue]), 0, [Gross Profit] / [Net Revenue])"
    },
    {
      "category": "calculation",
      "name": "Tax Amount",
      "status": "exact",
      "source_formula": "SUM([quantity] * [unit_price] * (1 - [discount_pct]) * [tax_rate])",
      "dax": "SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price] * (1 - 'fact_sales'[discount_pct]) * 'fact_sales'[tax_rate])"
    },
    {
      "category": "calculation",
      "name": "Total Revenue incl Tax",
      "status": "exact",
      "source_formula": "[C_NetRev] + [C_TaxAmt]",
      "dax": "[Net Revenue] + [Tax Amount]"
    },
    {
      "category": "calculation",
      "name": "Return Rate",
      "status": "exact",
      "source_formula": "SUM(IF [is_returned] = TRUE THEN 1 ELSE 0 END) / COUNT([sale_id])",
      "dax": "SUMX('fact_sales', IF('fact_sales'[is_returned] = TRUE, 1, 0)) / COUNT('fact_sales'[sale_id])"
    },
    {
      "category": "calculation",
      "name": "Revenue per Customer",
      "status": "exact",
      "source_formula": "{FIXED [customer_id] : SUM([quantity] * [unit_price])}",
      "dax": "CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), ALLEXCEPT('dim_customer', 'dim_customer'[customer_id]))"
    },
