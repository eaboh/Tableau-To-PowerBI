// DAX measures for table: fact_sales
// Auto-generated by Tableau → Power BI migration

Gross Revenue =
SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price])

Net Revenue =
SUMX('fact_sales', IF('fact_sales'[order_status] <> "Cancelled" && 'fact_sales'[is_returned] = FALSE, 'fact_sales'[quantity] * 'fact_sales'[unit_price] * (1 - 'fact_sales'[discount_pct]), 0))

COGS =
SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_cost])

Gross Profit =
[Net Revenue] - [COGS] - SUM('fact_sales'[shipping_cost])

Gross Margin % =
IF(ISBLANK([Gross Profit] / [Net Revenue]), 0, [Gross Profit] / [Net Revenue])

Tax Amount =
SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price] * (1 - 'fact_sales'[discount_pct]) * 'fact_sales'[tax_rate])

Total Revenue incl Tax =
[Net Revenue] + [Tax Amount]

Return Rate =
SUMX('fact_sales', IF('fact_sales'[is_returned] = TRUE, 1, 0)) / COUNT('fact_sales'[sale_id])

Revenue per Customer =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), ALLEXCEPT('dim_customer', 'dim_customer'[customer_id]))

Revenue per Product =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), ALLEXCEPT('dim_product', 'dim_product'[product_id]))

Revenue by Region-Channel =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), ALLEXCEPT('fact_sales', 'fact_sales'[region], 'fact_sales'[channel]))

Revenue excl Territory =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), REMOVEFILTERS('fact_sales'[territory]))

Revenue incl Subcategory =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]))

Running Total Revenue =
/* TODO: DAX conversion validation failed for C_RunTotal: unconverted Tableau function token detected in DAX output */ BLANK()

Running Avg Revenue =
/* TODO: DAX conversion validation failed for C_RunAvg: unconverted Tableau function token detected in DAX output */ BLANK()

Running Count =
/* TODO: DAX conversion validation failed for C_RunCount: unconverted Tableau function token detected in DAX output */ BLANK()

Revenue Rank =
RANKX(ALL('fact_sales'), SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]))

Revenue Rank Dense =
RANKX(ALL('fact_sales'), SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]),, ASC, DENSE)

Moving Avg 3-Period =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), WINDOW(-2, REL, 0, REL, ORDERBY(SUM('fact_sales'[sale_id]), ASC)), ALL('fact_sales')) /* WINDOW.AVG: frame SUM('fact_sales'[-2,0]) */
isHidden

Window Max Revenue =
CALCULATE(SUMX('fact_sales', 'fact_sales'[quantity] * 'fact_sales'[unit_price]), ALL('fact_sales'))

Revenue StdDev =
STDEVX.S('fact_sales', MAX('fact_sales'[quantity]) * MAX('fact_sales'[unit_price]))

Order Count =
DISTINCTCOUNT('fact_sales'[sale_id])

Unique Customers =
DISTINCTCOUNT('dim_customer'[customer_id])

Unique Products Sold =
DISTINCTCOUNT('dim_product'[product_id])

Customer Tier =
IF([Revenue per Customer] > 100000, "Enterprise", IF([Revenue per Customer] > 50000, "Mid-Market", IF([Revenue per Customer] > 10000, "SMB", "Startup")))

YTD Revenue =
CALCULATE(SUMX('dim_date', IF('dim_date'[year] = YEAR(TODAY()) && LOOKUPVALUE(fact_sales[is_returned], fact_sales[date_key], dim_date[date_key]) = FALSE, LOOKUPVALUE(fact_sales[quantity], fact_sales[date_key], dim_date[date_key]) * LOOKUPVALUE(fact_sales[unit_price], fact_sales[date_key], dim_date[date_key]), 0)), ALL('fact_sales'))

Is My Account =
SUM('dim_customer'[email]) = USERPRINCIPALNAME()

Manager Access =
TRUE() /* ISMEMBEROF("Regional Managers"): implement via RLS role */

Analysis Start Date =
DATE(2024, 1, 1)

Metric Selector =
"Revenue"

Display Currency =
"USD"

