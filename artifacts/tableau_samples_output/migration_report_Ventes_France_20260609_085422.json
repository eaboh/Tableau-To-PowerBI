      "name": "Chiffre d'Affaires Net",
      "status": "exact",
      "source_formula": "SUM(IF [statut] != \"Annulée\" THEN [quantite] * [prix_unitaire] * (1 - [remise]) ELSE 0 END)",
      "dax": "SUMX('Commandes', IF('Commandes'[statut] <> \"Annulée\", 'Commandes'[quantite] * 'Commandes'[prix_unitaire] * (1 - 'Commandes'[remise]), 0))"
