    {
      "category": "calculation",
      "name": "Gross Revenue",
      "status": "exact",
      "source_formula": "SUM([quantity] * [unit_price])",
      "dax": "SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price])"
    },
    {
      "category": "calculation",
      "name": "Net Revenue",
      "status": "exact",
      "source_formula": "SUM(IF [order_status] != \"Cancelled\" THEN [quantity] * [unit_price] * (1 - [discount]) ELSE 0 END)",
      "dax": "SUMX('Orders', IF('Orders'[order_status] <> \"Cancelled\", 'Orders'[quantity] * 'Orders'[unit_price] * (1 - 'Orders'[discount]), 0))"
    },
    {
      "category": "calculation",
      "name": "Total Discount",
      "status": "exact",
      "source_formula": "SUM([quantity] * [unit_price] * [discount])",
      "dax": "SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price] * 'Orders'[discount])"
    },
    {
      "category": "calculation",
      "name": "Profit",
      "status": "exact",
      "source_formula": "SUM(IF [order_status] != \"Cancelled\" THEN ([quantity] * [unit_price] * (1 - [discount])) - [shipping_cost] ELSE 0 END)",
      "dax": "SUMX('Orders', IF('Orders'[order_status] <> \"Cancelled\", ('Orders'[quantity] * 'Orders'[unit_price] * (1 - 'Orders'[discount])) - 'Orders'[shipping_cost], 0))"
    },
    {
      "category": "calculation",
      "name": "Profit Margin %",
      "status": "exact",
      "source_formula": "[Calc_Profit] / [Calc_NetRevenue]",
      "dax": "[Profit] / [Net Revenue]"
    },
    {
      "category": "calculation",
      "name": "Revenue per Customer",
      "status": "exact",
      "source_formula": "{FIXED [customer_id] : SUM([quantity] * [unit_price])}",
      "dax": "CALCULATE(SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price]), ALLEXCEPT('Orders', 'Orders'[customer_id]))"
    },
    {
      "category": "calculation",
      "name": "Regional Channel Revenue",
      "status": "exact",
      "source_formula": "{FIXED [region], [channel] : SUM([quantity] * [unit_price])}",
      "dax": "CALCULATE(SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price]), ALLEXCEPT('Orders', 'Orders'[region], 'Orders'[channel]))"
    },
    {
      "category": "calculation",
      "name": "Revenue Excl Category",
      "status": "exact",
      "source_formula": "{EXCLUDE [channel] : SUM([quantity] * [unit_price])}",
      "dax": "CALCULATE(SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price]), REMOVEFILTERS('Orders'[channel]))"
    },
    {
      "category": "calculation",
      "name": "Moving Avg Revenue",
      "status": "exact",
      "source_formula": "WINDOW_AVG(SUM([quantity] * [unit_price]))",
      "dax": "CALCULATE(SUMX('Orders', 'Orders'[quantity] * 'Orders'[unit_price]), ALL('Orders'))"
    },
    {
      "category": "calculation",
      "name": "Running Total Revenue",
      "status": "exact",
      "source_formula": "RUNNING_SUM(SUM([quantity] * [unit_price]))",
