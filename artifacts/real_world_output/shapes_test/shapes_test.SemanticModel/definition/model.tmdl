		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","People","Returns","Calendar","Top Customers","Profit Bin Size"]

ref table Orders
ref table People
ref table Returns
ref table Calendar
ref table 'Top Customers'
ref table 'Profit Bin Size'

ref relationship b517c91f-44ea-4fd8-a15f-48d50d8a78e6
ref relationship ada174ed-bd4d-4214-b26b-58dc4646f4f1
ref relationship b6bff024-a01d-452a-9bd7-84c445b3e24e

ref expression DataFolder

ref perspective 'Full Model'

