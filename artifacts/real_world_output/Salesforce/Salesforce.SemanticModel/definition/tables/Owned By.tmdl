table 'Owned By'
	lineageTag: ab234be8-66cd-4b53-a9be-3251efb3eb53

	measure 'Avg Probability (Open Opp.)' = AVERAGEX('Owned By', IF('Owned By'[Is Open Opportunity?], 'Owned By'[_Avg Probability (Expression)], BLANK()))
