	hierarchy 'Date Hierarchy'
		lineageTag: 45746f83-9a86-4d76-afe5-b09ea857b63e

		level Year
			ordinal: 0
			column: Year
			lineageTag: 02cb00db-dcb2-420f-8378-37e10fa5121d

		level Quarter
