table Calendar
	lineageTag: a99536f7-c533-462c-a20e-9b80afc15cfb

	measure 'Year To Date' = TOTALYTD([Margin], 'Calendar'[Date])
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: 173dea28-28e7-43b0-9c7e-70f85f40707b
		annotation Copilot_Description = DAX: TOTALYTD([Margin], 'Calendar'[Date])

	measure 'Previous Year' = CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))
		formatString: #,0.00
		displayFolder: Time Intelligence
		lineageTag: ea034803-40b3-4f0e-b6df-e17fa711a90a
		annotation Copilot_Description = DAX: CALCULATE([Margin], SAMEPERIODLASTYEAR('Calendar'[Date]))

	measure 'Year Over Year %' = DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)
		formatString: 0.00%
		displayFolder: Time Intelligence
		lineageTag: ff1e62b0-2de2-435c-b83c-5d1d6f5ac14b
		annotation Copilot_Description = DAX: DIVIDE([Year To Date] - [Previous Year], [Previous Year], 0)

