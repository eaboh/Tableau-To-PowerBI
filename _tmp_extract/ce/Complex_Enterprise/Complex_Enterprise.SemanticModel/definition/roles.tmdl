role 'Territory Access'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau user filter 'Territory Access'. Each user is mapped to their allowed territory values inline. Consider creating a security table for dynamic RLS."

	tablePermission fact_sales
		filterExpression = (USERPRINCIPALNAME() = "alice@company.com" && [territory] IN {"North America", "Europe"}) || (USERPRINCIPALNAME() = "bob@company.com" && [territory] = "Asia Pacific") || (USERPRINCIPALNAME() = "carol@company.com" && [territory] = "Latin America") || (USERPRINCIPALNAME() = "dave@company.com" && [territory] = "EMEA")

role 'Is My Account'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau calculated security 'Is My Account'. Original formula: [email] = USERNAME()"

	tablePermission dim_customer
		filterExpression = [email] = USERPRINCIPALNAME()

role 'Regional Managers'
	modelPermission: read
	annotation MigrationNote = "Migrated from Tableau ISMEMBEROF(\"Regional Managers\"). Assign Azure AD group members to this RLS role."

	tablePermission fact_sales
		filterExpression = TRUE()  /* Members of role 'Regional Managers' have access */

